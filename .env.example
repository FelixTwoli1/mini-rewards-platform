# ─────────────────────────────────────────────
# API GATEWAY
# ─────────────────────────────────────────────
API_GATEWAY_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# JWT AUTH  (change ALL secrets in production)
# ─────────────────────────────────────────────
AUTH_JWT_SECRET=replace-with-strong-secret-min-32-chars
AUTH_JWT_EXPIRATION=3600
AUTH_JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
AUTH_JWT_REFRESH_EXPIRATION=604800

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://rewards_user:rewards_pass@localhost:5432/rewards_db
POSTGRES_USER=rewards_user
POSTGRES_PASSWORD=rewards_pass
POSTGRES_DB=rewards_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────────────────
# REWARDS BUSINESS RULES
# ─────────────────────────────────────────────
SIGNUP_BONUS_POINTS=500
POINTS_TO_MONEY_CONVERSION=100
REDEMPTION_MIN_POINTS=100

# ─────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=rewards-platform
KAFKA_GROUP_ID=rewards-consumer-group

# ─────────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
OTEL_ENABLED=false
