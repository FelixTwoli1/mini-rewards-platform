# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_LOG_LEVEL=info

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_DATABASE_URL=postgresql://rewards_user:rewards_pass@postgres:5432/rewards_db
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production
AUTH_JWT_EXPIRATION=3600
AUTH_JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
AUTH_JWT_REFRESH_EXPIRATION=604800

# Rewards Service
REWARDS_SERVICE_PORT=3002
REWARDS_DATABASE_URL=postgresql://rewards_user:rewards_pass@postgres:5432/rewards_db

# Wallet Service
WALLET_SERVICE_PORT=3003
WALLET_DATABASE_URL=postgresql://rewards_user:rewards_pass@postgres:5432/rewards_db

# Database
DATABASE_URL=postgresql://rewards_user:rewards_pass@postgres:5432/rewards_db
POSTGRES_USER=rewards_user
POSTGRES_PASSWORD=rewards_pass
POSTGRES_DB=rewards_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BROKER=kafka:29092
KAFKA_BROKERS=kafka:29092

# RabbitMQ (alternative to Kafka)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Observability
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
LOG_LEVEL=info

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=admin

# Messaging Provider (kafka or rabbitmq)
MESSAGING_PROVIDER=kafka

# Point Conversion
POINTS_TO_MONEY_CONVERSION=100

# Node Environment
NODE_ENV=development
